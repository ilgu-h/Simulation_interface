# Host virtualenvs & build artifacts — must not overwrite in-image copies
.venv-backend/
frontend/node_modules/
frontend/.next/

# Host-built ASTRA-sim binary — must be compiled inside the image so it
# links against the container's libprotobuf, not the host's.
frameworks/astra-sim/build/astra_analytical/build/

# Runtime data
runs/

# Git history (not needed in image)
.git/

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store
__pycache__/
*.pyc
